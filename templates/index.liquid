<section id="heritage-atlas"
         class="site-section"
         aria-label="Heritage Atlas — Artifacts in the World">
  <div class="content-wrap" style="margin-bottom: 2rem;">
    <span class="section-label">The Atlas</span>
    <h2 class="section-title fade-in">
      Heritage Atlas
    </h2>
    <p class="section-body fade-in"
       style="opacity: 0.5; font-size: 0.8rem;">
      Each mark is an artifact in the world.
    </p>
  </div>

  <div id="world-map"
       role="img"
       aria-label="World map showing artifact destinations">
  </div>

  <!-- Leaflet.js map initialization -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {

      var map = L.map('world-map', {
        center: [30, 0],
        zoom: 2,
        zoomControl: false,
        attributionControl: false,
        scrollWheelZoom: false
      });

      L.tileLayer(
        'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',
        { maxZoom: 19 }
      ).addTo(map);

      // Shipped destinations
      // Replace with dynamic data from Shopify metaobjects in production
      var destinations = [
        { coords: [40.7128, -74.0060], city: "New York, USA" },
        { coords: [34.0522, -118.2437], city: "Los Angeles, USA" },
        { coords: [43.6532, -79.3832], city: "Toronto, Canada" },
        { coords: [51.5074, -0.1278], city: "London, UK" },
        { coords: [48.8566, 2.3522], city: "Paris, France" },
        { coords: [52.5200, 13.4050], city: "Berlin, Germany" },
        { coords: [35.6762, 139.6503], city: "Tokyo, Japan" },
        { coords: [-33.8688, 151.2093], city: "Sydney, Australia" },
        { coords: [1.3521, 103.8198], city: "Singapore" },
        { coords: [55.7558, 37.6173], city: "Moscow, Russia" }
      ];

      destinations.forEach(function(d) {
        L.circleMarker(d.coords, {
          radius: 4,
          fillColor: '#111111',
