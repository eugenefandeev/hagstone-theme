## ФАЙЛ 3 из 4 — Главная страница

Нажми **"Add file"** → **"Create new file"**

В поле **"Name your file"** введи точно:
```
templates/index.liquid
```

Вставь весь код ниже:

```liquid
<!-- ============================================================
     HAGSTONE.FR — HOMEPAGE
     7 sections: Lottery, Manifesto, Heritage, Gallery,
     Matchmaker, Commission, Awakening, Portal, Atlas
============================================================ -->

<!-- ============================================================
     SECTION 1 — THE DAILY RESONANCE
     Left: today's artifact + countdown + email form
     Right: scrollable archive of past draws
============================================================ -->
<section id="daily-resonance"
         class="site-section"
         aria-label="Daily Artifact Draw">
  <div class="content-wrap">

    <span class="section-label">Daily Draw</span>

    <div class="lottery-grid">

      <!-- LEFT: Today's artifact -->
      <div class="lottery-left">

        <h2 class="section-title">Today's Artifact</h2>

        {% assign lottery_product = collections['lottery-today'].products.first %}
        {% if lottery_product %}
          <img
            src="{{ lottery_product.featured_image | img_url: 'master' }}"
            alt="{{ lottery_product.title | escape }}"
            class="lottery-artifact-image fade-in">
          <p class="artifact-name">{{ lottery_product.title }}</p>
          {% if lottery_product.metafields.custom.height_cm.value %}
            <p class="artifact-dims">
              {{ lottery_product.metafields.custom.height_cm.value }} cm
              · {{ lottery_product.metafields.custom.weight_g.value }} g
            </p>
          {% endif %}
        {% else %}
          <!-- Placeholder when no lottery product is set -->
          <div style="height: 300px; border: 1px solid #E0E0E0;
                      display: flex; align-items: center;
                      justify-content: center; opacity: 0.3;">
            <span style="font-size: 0.7rem; letter-spacing: 0.2em;">
              ARTIFACT TO BE REVEALED
            </span>
          </div>
        {% endif %}

        <!-- Countdown timer -->
        <div class="lottery-timer" style="margin-top: 2rem;">
          <span class="timer-label">Next draw in</span>
          <span class="timer-countdown" id="countdown">--:--:--</span>
        </div>

        <!-- Email entry form -->
        <form class="lottery-form"
              action="/contact#contact_form"
              method="post"
              id="lottery-form">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="✓">
          <input
            type="email"
            name="contact[email]"
            class="field-input"
            placeholder="Your email — enter the draw"
            required
            aria-label="Email address for lottery entry">
          <button type="submit" class="btn-ghost">
            [ Enter ]
          </button>
        </form>

      </div>

      <!-- RIGHT: Archive of past draws -->
      <div class="lottery-right">

        <h3 class="section-title" style="font-size: 0.8rem;">
          Archive
        </h3>

        <ul class="archive-list" aria-label="Past artifact draws">
          {% for entry in shop.metaobjects.lottery_archive.values limit: 20 %}
            <li class="archive-item">
              {% if entry.artifact_image.value %}
                <img
                  src="{{ entry.artifact_image.value | img_url: '80x80' }}"
                  alt="{{ entry.artifact_title.value }}"
                  class="archive-thumb">
              {% else %}
                <div class="archive-thumb"
                     style="background: #F0F0F0;"></div>
              {% endif %}
              <span class="archive-name">
                {{ entry.artifact_title.value }}
              </span>
              <span class="archive-city">
                → {{ entry.winner_city.value }},
                {{ entry.winner_country.value }}<br>
                <span style="opacity: 0.4; font-size: 0.6rem;">
                  {{ entry.draw_date.value | date: '%b %d' }}
                </span>
              </span>
            </li>
          {% else %}
            <!-- Placeholder items before first real draws -->
            <li class="archive-item">
              <div class="archive-thumb" style="background: #F0F0F0;"></div>
              <span class="archive-name">Stone #001</span>
              <span class="archive-city">→ New York, USA</span>
            </li>
            <li class="archive-item">
              <div class="archive-thumb" style="background: #F0F0F0;"></div>
              <span class="archive-name">Stone #002</span>
              <span class="archive-city">→ Tokyo, Japan</span>
            </li>
            <li class="archive-item">
              <div class="archive-thumb" style="background: #F0F0F0;"></div>
              <span class="archive-name">Stone #003</span>
              <span class="archive-city">→ London, UK</span>
            </li>
            <li class="archive-item">
              <div class="archive-thumb" style="background: #F0F0F0;"></div>
              <span class="archive-name">Stone #004</span>
              <span class="archive-city">→ Berlin, Germany</span>
            </li>
            <li class="archive-item">
              <div class="archive-thumb" style="background: #F0F0F0;"></div>
              <span class="archive-name">Stone #005</span>
              <span class="archive-city">→ Sydney, Australia</span>
            </li>
          {% endfor %}
        </ul>

      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     SECTION 2 — THE DEEP TIME MANIFESTO
============================================================ -->
<section id="deep-time-manifesto"
         class="site-section section--centered"
         aria-label="Deep Time Manifesto">
  <div class="content-wrap">

    <span class="section-label">The Manifesto</span>

    <h2 class="section-title fade-in">
      Before Words Were Spoken
    </h2>

    <p class="section-body fade-in">
      A hagstone is not merely a geological anomaly; it is a physical
      anchor to Deep Time. Before words were spoken, before temples were
      built and sacred texts written, there was the stone. This natural
      portal has accompanied the human species for over two million years
      of evolution. Carved by the abrasive tides of the Atlantic, it is
      the ocean's ultimate sculpture and the original manuport.
    </p>

    <!-- Geological data points -->
    <div class="data-grid fade-in">
      <div>
        <span class="data-label">Geological Age</span>
        <span class="data-value">60–95 million years</span>
      </div>
      <div>
        <span class="data-label">Formation</span>
        <span class="data-value">Late Cretaceous</span>
      </div>
      <div>
        <span class="data-label">Origin</span>
        <span class="data-value">Atlantic seabed</span>
      </div>
      <div>
        <span class="data-label">Human Bond</span>
        <span class="data-value">2+ million years</span>
      </div>
    </div>

  </div>
</section>

<!-- ============================================================
     SECTION 3 — THE HERITAGE ARCHIVE
============================================================ -->
<section id="heritage-archive"
         class="site-section"
         aria-label="Heritage Archive">
  <div class="content-wrap">
    <div class="two-col" style="align-items: center;">

      <div>
        <span class="section-label">The Archive</span>
        <h2 class="section-title fade-in">
          The Normandie Archive:<br>Since 1928
        </h2>
        <p class="section-body fade-in">
          For nearly a century, our curators have walked the unforgiving
          shores of the Normandie coast, France. We do not manufacture
          these artifacts; we recover them. Since 1928, our family has
          preserved the rarest specimens shaped by water and wind. Each
          piece in our gallery is an absolute singularity — never to be
          replicated by man or nature.
        </p>
      </div>

      <!-- Normandie image — upload to Shopify Files as normandie.jpg -->
      <div class="fade-in">
        {% assign normandie_img = 'normandie.jpg' | asset_url %}
        <img src="{{ normandie_img }}"
             alt="Normandie coastline — hagstone collection site"
             style="width: 100%; height: auto; object-fit: cover;
                    filter: grayscale(20%);">
      </div>

    </div>
  </div>
</section>

<!-- ============================================================
     SECTION 4 — THE ABSOLUTE GEOMETRY
     Masonry grid — artifacts at relative scale
============================================================ -->
<section id="absolute-geometry"
         class="site-section"
         aria-label="Artifact Gallery">
  <div class="content-wrap">

    <span class="section-label">The Collection</span>
    <h2 class="section-title fade-in">The Archive</h2>
    <p class="section-body fade-in"
       style="margin-bottom: 3rem; opacity: 0.5; font-size: 0.8rem;">
      Artifacts displayed at relative scale. Dimensions are exact.
      Each piece is a singularity.
    </p>

    <div class="artifact-grid">
      {% for product in collections.all.products limit: 200 %}

        {% assign h = product.metafields.custom.height_cm.value
                      | default: 25 | plus: 0 %}
        {% assign scale = h | divided_by: 25.0 %}

        <a href="{{ product.url }}"
           class="artifact-card fade-in"
           aria-label="{{ product.title }}">

          <div class="artifact-image-wrap">

            <!-- Clean image (no hand) — shown by default -->
            {% if product.images[1] %}
              <img
                src="{{ product.images[1] | img_url: 'master' }}"
                alt="{{ product.title | escape }} — artifact"
                class="artifact-image-clean"
                style="transform: scale({{ scale }});
                       transform-origin: bottom center;"
                loading="lazy"
                width="{{ product.images[1].width }}"
                height="{{ product.images[1].height }}">
            {% else %}
              <img
                src="{{ product.featured_image | img_url: 'master' }}"
                alt="{{ product.title | escape }}"
                class="artifact-image-clean"
                style="transform: scale({{ scale }});
                       transform-origin: bottom center;"
                loading="lazy">
            {% endif %}

            <!-- Hand image — shown on hover -->
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | img_url: 'master' }}"
                alt="{{ product.title | escape }} — in hand"
                class="artifact-image-hand"
                loading="lazy">
            {% endif %}

          </div>

          <div class="artifact-meta">
            <span class="artifact-number">
              #{{ product.metafields.custom.stone_number.value
                  | default: forloop.index
                  | prepend: '00'
                  | slice: -3, 3 }}
            </span>
            <span class="artifact-name">{{ product.title }}</span>
            {% if product.metafields.custom.height_cm.value %}
              <span class="artifact-dims">
                {{ product.metafields.custom.height_cm.value }} cm
                · {{ product.metafields.custom.weight_g.value }} g
              </span>
            {% endif %}
            <span class="artifact-price">
              {{ product.price | money }}
            </span>
          </div>

        </a>

      {% endfor %}
    </div>

  </div>
</section>

